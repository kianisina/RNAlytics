y="-Log10 Adjusted p-value") +
# 3. CRITICAL FIX: inherit.aes = FALSE protects these lines from crashing Plotly
geom_vline(xintercept=c(-1, 1), linetype="dashed", color="black", inherit.aes = FALSE) +
